# Public browser settings.
# These are safe to expose to the browser.
NEXT_PUBLIC_SITE_URL=https://goldenbagelcafe.com

# Vercel: leave blank so the frontend uses same-origin /api.
# Only set this if the frontend calls a separate backend URL.
NEXT_PUBLIC_API_BASE_URL=

NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=
NEXT_PUBLIC_ENABLE_ORDERING=true

# false = real API route / Clover checkout. true = browser mock checkout.
NEXT_PUBLIC_MOCK_ORDERING=false

# Server-only settings for Vercel API routes.
# Do not prefix these with NEXT_PUBLIC.
ALLOWED_ORIGIN=https://goldenbagelcafe.com
MOCK_CLOVER=false

# Clover basics.
CLOVER_ENV=production
CLOVER_MERCHANT_ID=6EE1NRRRY8KS1

# Required for live Clover hosted checkout.
CLOVER_ECOMMERCE_PRIVATE_KEY=

# Optional Clover settings. Leave blank unless you are using that feature.
CLOVER_ONLINE_ORDERING_URL=https://golden-bagel-el-cajon.cloveronline.com/
CLOVER_ACCESS_TOKEN=
CLOVER_ECOMMERCE_PUBLIC_KEY=
CLOVER_WEBHOOK_SECRET=
CLOVER_API_BASE_URL=
CLOVER_ECOMMERCE_API_BASE_URL=
CLOVER_HOSTED_CHECKOUT_PAGE_CONFIG_UUID=
CLOVER_CHECKOUT_SUCCESS_URL=
CLOVER_CHECKOUT_FAILURE_URL=
CLOVER_HOSTED_CHECKOUT_TAX_NAME=Sales tax
CLOVER_HOSTED_CHECKOUT_TAX_RATE=

# Owner notification email.
# Leave blank to log submissions/orders only.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
NOTIFY_TO=
USE_SES=false
AWS_REGION=us-west-2
